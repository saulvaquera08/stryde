# ─── Supabase ───────────────────────────────────────────────────────────────
# Project Settings → API  →  https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # keep secret — server only

# ─── Anthropic ──────────────────────────────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── App URL ─────────────────────────────────────────────────────────────────
# localhost for dev; your Vercel URL (or custom domain) for production.
# Also set this in Supabase → Auth → URL Configuration → Site URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
