{
  "version": "2.0",
  "programs": ["gym", "run"],
  "gym": {
    "philosophy": [
      "Evidence-based training (Jeff Nippard principles)",
      "Progressive overload via double progression (reps first, then weight)",
      "Compound movements before isolation",
      "Explicit tempo for time under tension",
      "RIR-based intensity (not just percentage)",
      "Deload every 4-6 weeks"
    ],
    "available_splits": ["ppl", "upper_lower", "full_body"],
    "progression": {
      "weeks_1_2": "familiarization — 3 sets @3 RIR",
      "weeks_3_4": "accumulation — 4 sets @2 RIR",
      "week_5": "intensification — 5 sets @1 RIR",
      "week_6": "deload — 2 sets @4 RIR, -40% volume"
    },
    "rules": {
      "always_warmup_sets_for_compounds": true,
      "always_include_tempo": true,
      "rest_times": {
        "compound_heavy": "3-4 min",
        "compound_moderate": "2-3 min",
        "isolation": "60-90s"
      }
    }
  },
  "run": {
    "philosophy": [
      "80/20 rule: 80% easy, 20% quality sessions",
      "Never increase weekly volume more than 10%",
      "Two quality sessions max per week",
      "Long run is sacred — never skip",
      "Zone 2 is the foundation of endurance"
    ],
    "session_types": ["easy", "tempo", "intervals", "long_run", "fartlek", "recovery"],
    "heart_rate_zones": {
      "Z1": "50-60% HRmax — recovery/warmup",
      "Z2": "60-70% HRmax — conversational, aerobic base",
      "Z3": "70-80% HRmax — comfortably uncomfortable",
      "Z4": "80-90% HRmax — threshold/tempo",
      "Z5": "90-100% HRmax — VO2max/intervals"
    },
    "objectives": ["5k", "10k", "half_marathon", "marathon"],
    "plan_lengths": {
      "5k": 8,
      "10k": 10,
      "half_marathon": 12,
      "marathon": 16
    }
  }
}
