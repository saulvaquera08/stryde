        "notes": "Alta repetición, simula fatiga HYROX"
      }
    ],

    "hyrox_simulation": [
      {
        "id": "HX_A",
        "name": "HYROX Full Sim",
        "format": "8 rounds: 400m run + 1 station",
        "stations": [
          "SkiErg 250m (o remo)",
          "Sled push 25m (o empuje de placa)",
          "Sled pull 25m (o banda resistencia)",
          "Burpee broad jumps 20m",
          "Remo 250m",
          "Farmer carry 50m",
          "Walking lunges con saco 25m",
          "Wall balls 25 reps"
        ],
        "duration": 75,
        "intensity": "high",
        "notes": "Simula la carrera completa — pacing crítico"
      },
      {
        "id": "HX_B",
        "name": "HYROX Half Sim",
        "format": "4 rounds: 400m run + 1 station (primeras 4)",
        "stations": [
          "SkiErg 250m",
          "Sled push/pull 25m",
          "Burpee broad jumps 20m",
          "Farmer carry 50m"
        ],
        "duration": 50,
        "intensity": "high"
      },
      {
        "id": "HX_C",
        "name": "HYROX Stations Only",
        "format": "Circuito sin correr — foco en técnica y resistencia muscular",
        "exercises": [
          "SkiErg 500m",
          "Sled push 50m",
          "Burpees 20 reps",
          "Farmer carry 80m",
          "Wall balls 30 reps",
          "Walking lunges 50m"
        ],
        "rounds": 3,
        "rest": "90s entre estaciones",
        "duration": 48,
        "intensity": "moderate"
      },
      {
        "id": "HX_D",
        "name": "Run + Fatigue",
        "format": "Carrera con estaciones intercaladas — simula fatiga acumulada",
        "blocks": [
          "1km tempo + 15 burpees",
          "1km tempo + 20 walking lunges",
          "1km tempo + 30 wall balls",
          "1km easy"
        ],
        "duration": 55,
        "intensity": "high",
        "notes": "Entrena como compites: run + fatigue muscular"
      }
    ],

    "zone2_run": [
      {
        "id": "Z2_A",
        "name": "Easy Base Run",
        "duration": 45,
