[{
  "philosophy": [
    "Never sacrifice motor (cardio base)",
    "Strength = performance, not aesthetics",
    "Train as you compete: run + fatigue",
    "No more than 2 consecutive high intensity days",
    "Always maintain aerobic base (Z2)"
  ],
  "weekly_structure": {
    "day_1": {
      "label": "Strength Lower + Intervals",
      "blocks": ["strength_lower", "intervals"],
      "intensity": "high",
      "goal": "Power + lactate tolerance"
    },
    "day_2": {
      "label": "Z2 Run + Accessory",
      "blocks": ["zone2_run"],
      "intensity": "low",
      "goal": "Aerobic base + active recovery"
    },
    "day_3": {
      "label": "HYROX Simulation",
      "blocks": ["hyrox_simulation"],
      "intensity": "high",
      "goal": "Race specificity"
    },
    "day_4": {
      "label": "Upper Strength + Tempo",
      "blocks": ["strength_upper", "tempo"],
      "intensity": "moderate",
      "goal": "Sustained effort"
    },
    "day_5": {
      "label": "Long Endurance",
      "blocks": ["long_run"],
      "intensity": "moderate",
      "goal": "Long endurance"
    }
  },
  "intensity_distribution": {
    "high_intensity_days": 2,
    "moderate_days": 2,
    "low_intensity_days": 1
  },
  "progression_6_weeks": {
    "weeks_1_2": "build_volume",
    "weeks_3_4": "increase_intensity",
    "week_5": "peak_simulation",
    "week_6": "taper"
  },
  "constraints": {
    "no_consecutive_high_intensity": true,
    "min_zone2_sessions_per_week": 1,
    "min_strength_sessions_per_week": 2,
    "min_hyrox_sessions_per_week": 1,
    "max_training_days": 5
  },
  "multi_goal_logic": {
    "priority_rule": "closest_event_is_primary",
    "secondary_rule": "maintenance_only",
    "hyrox_phase": {
      "weeks": "1-6",
      "priority": "hyrox",
      "maintain": ["1_long_run", "1_zone2"]
    },
    "half_marathon_phase": {
      "weeks": "7-10",
      "priority": "21k",
      "reduce": ["heavy_strength", "hyrox_circuits"],
      "increase": ["running_volume", "tempo_runs"]
    }
  },
  "workout_library": {

    "strength_lower": [
      {
        "id": "SL_A",
        "name": "Power Lower A",
        "exercises": [
          "Deadlift 4x5 @80%",
          "Bulgarian split squat 3x8 cada pierna",
          "Romanian deadlift 3x10",
          "Box jumps 4x5"
        ],
        "rest": "2-3 min pesados / 90s accesorios",
        "duration": 55,
        "notes": "Fuerza primero, potencia al final"
      },
      {
        "id": "SL_B",
        "name": "Power Lower B",
        "exercises": [
          "Back squat 4x5 @80%",
          "Step-ups con mancuernas 3x10",
          "Good mornings 3x12",
          "Broad jumps 3x4"
        ],
        "rest": "2-3 min / 90s",
        "duration": 55
      },
      {
        "id": "SL_C",
        "name": "Strength Endurance Lower",
        "exercises": [
          "Front squat 4x6",
          "Walking lunges con carga 4x12",
          "Single leg RDL 3x10",
          "Saltos al cajón 3x6"
        ],
        "rest": "90s",
        "duration": 50
      },
      {
        "id": "SL_D",
        "name": "Posterior Chain Focus",
        "exercises": [
          "Sumo deadlift 4x5",
          "Hip thrust 4x10",
          "Nordic curl 3x6",
          "Kettlebell swing 4x15"
        ],
        "rest": "2 min / 60s",
        "duration": 50
      }
    ],

    "strength_upper": [
      {
        "id": "SU_A",
        "name": "Push/Pull A",
        "exercises": [
          "Bench press 4x6",
          "Pull-ups 4x6",
          "DB shoulder press 3x10",
          "Cable row 3x10",
          "Tricep dips 2x12"
        ],
        "rest": "90s",
        "duration": 52
      },
      {
        "id": "SU_B",
        "name": "Push/Pull B",
        "exercises": [
          "Incline DB press 4x8",
          "Barbell row 4x6",
          "Arnold press 3x10",
          "Face pulls 3x15",
          "Chin-ups 3x max"
        ],
        "rest": "90s",
        "duration": 50
      },
      {
        "id": "SU_C",
        "name": "Upper Endurance",
        "exercises": [
          "Push-ups 4x20",
          "TRX row 4x15",
