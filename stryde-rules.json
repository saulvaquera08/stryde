  "weekly_rotation": {
    "description": "Rotar variantes A/B/C/D para que nunca se repita el mismo workout dos semanas seguidas",
    "rule": "semana_1=A, semana_2=B, semana_3=C, semana_4=D, semana_5=A+10%_volumen, semana_6=taper"
  },

  "zone_distribution": {
    "hyrox":          { "z1_z2": "50%", "z3": "25%", "z4_z5": "25%" },
    "half_marathon":  { "z1_z2": "75%", "z3": "15%", "z4_z5": "10%" },
    "combined":       { "z1_z2": "65%", "z3": "15%", "z4_z5": "20%" }
  },

  "concurrent_training_rules": {
    "max_concurrent_sessions_per_week": 3,
    "order_when_same_day": {
      "priority_strength":  "fuerza primero, cardio después",
      "priority_endurance": "cardio primero, fuerza después"
    },
    "avoid": "fuerza al fallo + cardio alta intensidad en misma sesión"
  }
}]
