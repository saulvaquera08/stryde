        "hr_zone": 2
      },
      {
        "id": "Z2_C",
        "name": "Z2 + Core",
        "duration": 55,
        "structure": "40 min Z2 + 15 min core (plank, dead bug, bird dog)",
        "hr_zone": 2
      },
      {
        "id": "Z2_D",
        "name": "Easy Run + Mobility",
        "duration": 60,
        "structure": "45 min Z2 + 15 min movilidad dinámica",
        "hr_zone": 2
      }
    ],

    "intervals": [
      {
        "id": "INT_A",
        "name": "Track 400s",
        "format": "Calentamiento 15 min + 6x400m al ritmo 5K + enfriamiento 10 min",
        "rest": "90s entre repeticiones",
        "pace": "RPE 8-9",
        "duration": 50,
        "intensity": "high",
        "notes": "Mejora VO2max — clave para HYROX y 21K"
      },
      {
        "id": "INT_B",
        "name": "1K Repeats",
        "format": "Calentamiento 15 min + 5x1000m + enfriamiento 10 min",
