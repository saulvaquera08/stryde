      },
      {
        "id": "LR_C",
        "name": "Long Run + Strides",
        "duration": 80,
        "structure": "65 min Z2 + 6 strides de 20s al final",
        "intensity": "low-moderate"
      },
      {
        "id": "LR_D",
        "name": "Hybrid Long",
        "duration": 75,
        "structure": "45 min Z2 + 3 rondas (5 min Z3 + 5 min Z2)",
