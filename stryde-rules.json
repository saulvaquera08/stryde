        "pace": "RPE 8-9",
        "duration": 55,
        "intensity": "high"
      },
      {
        "id": "INT_D",
        "name": "Short Speed",
        "format": "Calentamiento 15 min + 10x200m + enfriamiento",
        "rest": "60s",
        "pace": "RPE 9, sprint controlado",
        "duration": 45,
        "intensity": "high",
        "notes": "Potencia + economía de carrera"
      },
      {
        "id": "INT_E",
        "name": "Fartlek",
        "format": "30 min: alterna 2 min rápido / 3 min fácil",
