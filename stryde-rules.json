        "pace": "RPE 8, ritmo 10K objetivo",
        "duration": 55,
        "intensity": "high"
      },
      {
        "id": "INT_C",
        "name": "Pyramid Intervals",
        "format": "400m + 800m + 1200m + 800m + 400m",
