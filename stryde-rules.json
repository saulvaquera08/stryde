        "intensity": "moderate-high",
        "notes": "Versión no estructurada de intervalos — bueno para variedad"
      }
    ],

    "tempo": [
      {
        "id": "TMP_A",
        "name": "Classic Tempo",
        "format": "15 min easy + 25 min tempo continuo + 10 min easy",
        "pace": "RPE 7 — comfortably hard, puedes decir frases cortas",
        "duration": 50,
        "intensity": "moderate"
      },
      {
        "id": "TMP_B",
        "name": "Cruise Intervals",
        "format": "3x10 min tempo con 2 min descanso",
        "pace": "RPE 7",
        "duration": 50,
        "intensity": "moderate"
      },
      {
        "id": "TMP_C",
        "name": "Progressive Tempo",
        "format": "20 min: empieza Z2, termina Z3-4 los últimos 5 min",
