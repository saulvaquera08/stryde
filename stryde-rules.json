    "recovery": [
      {
        "id": "REC_A",
        "name": "Active Recovery",
        "structure": "20 min caminata o bici suave + 20 min foam rolling + 10 min stretching",
        "duration": 50,
        "intensity": "very_low"
      },
      {
        "id": "REC_B",
        "name": "Mobility Flow",
        "structure": "30 min movilidad dinámica + 15 min yoga básico",
